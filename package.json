{
  "name": "nexusone",
  "version": "2.0.1",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "node build-android.js",
    "build:android-debug": "expo run:android --variant debug",
    "build:android-release": "expo run:android --variant release",
    "build:android-eas": "eas build --platform android --profile development",
    "metro-start": "npx react-native start --reset-cache",
    "bundle-android": "npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res --reset-cache",
    "clean": "npm cache clean --force && npx expo start --clear && cd android && ./gradlew clean && cd ..",
    "setup": "npm install && npx expo install --fix",
    "gen:payment-icons": "node scripts/genPaymentIcons.js"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.12",
    "@sentry/react-native": "~7.2.0",
    "axios": "^1.12.2",
    "expo": "^54.0.0",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.12",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-intent-launcher": "~13.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-navigation-bar": "^5.0.10",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "jwt-decode": "^4.0.0",
    "pdf-lib": "^1.17.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.64",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-worklets": "0.5.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-webview": "13.15.0",
    "xlsx": "^0.18.5",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-preset-expo": "~54.0.10",
    "@react-native/metro-babel-transformer": "^0.81.0",
    "@react-native-community/cli": "^15.0.0",
    "@types/react": "~19.1.10",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "metro": "^0.83.1",
    "metro-config": "^0.83.1",
    "metro-resolver": "^0.83.1",
    "react-native-svg-transformer": "^1.5.2",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-chart-kit",
          "react-native-vector-icons"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "overrides": {
    "baseline-browser-mapping": "^2.9.0"
  },
  "private": true
}
